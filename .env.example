# ─── Server ───────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── MongoDB (get free DB from mongodb.com/atlas) ─────────
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASS@cluster0.xxxxx.mongodb.net/zeemebase

# ─── Base Mainnet RPC ──────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
BASE_CHAIN_ID=8453

# ─── Your Builder Code from base.dev ──────────────────────
BUILDER_CODE=bc_3apktcmn

# ─── Basescan API (free at basescan.org/apis) ─────────────
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY

# ─── Frontend URL (your Netlify URL) ──────────────────────
FRONTEND_URL=https://your-app.netlify.app

# ─── Secret for API security ──────────────────────────────
API_SECRET=change_this_to_random_long_string
